# ============================================================
# Smart Wardrobe AI — Frontend Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your actual values.
# Never commit .env.local to version control.
#
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.
# Never expose backend secrets (like GEMINI_API_KEY or USER_AI_KEY_ENCRYPTION_SECRET) in frontend env files.
# ============================================================

# --- Backend API ---
# In development: http://localhost:8000/api
# In production: point to your deployed backend URL + /api path
# The Next.js rewrite layer also derives host/port from this URL.
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# --- App Metadata ---
NEXT_PUBLIC_APP_NAME="Smart Wardrobe AI"

# --- Google OAuth (Optional) ---
# Client ID used for Google Sign-In button on frontend
NEXT_PUBLIC_GOOGLE_CLIENT_ID="your_google_client_id_here"


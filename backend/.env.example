# ============================================================
# Smart Wardrobe AI — Backend Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual values.
# Never commit .env to version control.
# ============================================================

# --- Database ---
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/smart_wardrobe
# For sync operations (Alembic): postgresql://user:password@localhost:5432/smart_wardrobe

# --- JWT Authentication ---
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- AWS S3 ---
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=smart-wardrobe-uploads

# --- AI Provider ---
# Options: mock, gemini, nvidia, huggingface
AI_PROVIDER=mock

# Gemini (if AI_PROVIDER=gemini)
GEMINI_API_KEY=your-gemini-api-key

# NVIDIA NIM (if AI_PROVIDER=nvidia)
NVIDIA_API_KEY=your-nvidia-api-key

# Hugging Face (if AI_PROVIDER=huggingface)
HF_API_KEY=your-huggingface-api-key

# --- Google OAuth ---
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# --- CORS ---
CORS_ORIGINS=http://localhost:3000

# --- App ---
APP_NAME=Smart Wardrobe AI
APP_VERSION=0.1.0
DEBUG=true

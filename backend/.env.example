# ============================================================
# Smart Wardrobe AI — Backend Environment Variables Template
# ============================================================
# Copy this to .env and fill in your actual values.
# Do NOT commit your actual .env file to version control.
# ============================================================

# --- Project ---
PROJECT_NAME="Smart Wardrobe AI"
DEBUG=false
ENVIRONMENT="development" # Change to "production" in production deployments

# --- Database (PostgreSQL) ---
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/wardrobe_db"

# --- JWT Authentication ---
# Generate a secure 64-character hex string for production
SECRET_KEY="generate_a_secure_random_string_here"
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# User AI Provider Encryption
# Must be a valid Fernet key to encrypt user Gemini API keys in the database.
# Generate in python: from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())
USER_AI_KEY_ENCRYPTION_SECRET=your_generated_fernet_key_here

# --- Google OAuth (Optional / Phase 2) ---
# Get these from Google Cloud Console
# GOOGLE_CLIENT_ID="your_google_client_id"
# GOOGLE_CLIENT_SECRET="your_google_client_secret"

# --- Gemini AI (Optional Platform Fallback) ---
# In BYOK mode, this key is only used as a fallback if PLATFORM_AI_FALLBACK_ENABLED=true or for admin/dev tasks.
GEMINI_API_KEY="your_gemini_api_key_here"

# --- NVIDIA NIM AI (Optional Platform Fallback) ---
# In BYOK mode, this key is only used as a fallback if PLATFORM_AI_FALLBACK_ENABLED=true or for admin/dev tasks.
NVIDIA_API_KEY="your_nvidia_api_key_here"

# --- OpenWeather ---
OPENWEATHER_API_KEY="your_openweather_api_key_here"

# --- AI Provider Routing ---
AI_PRIMARY_PROVIDER="gemini"
AI_FALLBACK_PROVIDER="nvidia"

# --- AI Usage Quotas (BYOK Architecture) ---
# It is recommended to disable platform fallback for production BYOK deployments.
PLATFORM_AI_FALLBACK_ENABLED=false

# (Deprecated / Internal Backend Compatibility)
# These values remain for backward compatibility with the database schema
# but no longer affect the normal user UI which relies entirely on BYOK.
PLATFORM_AI_QUOTA_ENABLED=true
AI_QUOTA_FREE_DAILY_LIMIT=10
AI_QUOTA_PREMIUM_DAILY_LIMIT=100
AI_QUOTA_PRO_DAILY_LIMIT=500
PLATFORM_AI_FREE_DAILY_LIMIT=10

# --- AI Cost Estimation (Optional) ---
# AI_COST_GEMINI_INPUT_PER_1M_TOKENS=0.35
# AI_COST_GEMINI_OUTPUT_PER_1M_TOKENS=1.05
# AI_COST_NVIDIA_INPUT_PER_1M_TOKENS=0.50
# AI_COST_NVIDIA_OUTPUT_PER_1M_TOKENS=1.50

# --- Frontend CORS ---
# Comma-separated list of allowed origins
FRONTEND_URLS="http://localhost:3000,http://127.0.0.1:3000"

# --- File Uploads ---
UPLOAD_DIR="uploads"
MAX_UPLOAD_SIZE_MB=10


# API Settings
API_V1_STR="/api/v1"
PROJECT_NAME="Smart Wardrobe AI"

# Database
DATABASE_URL="postgresql+asyncpg://user:password@localhost:5432/smart_wardrobe"

# JWT Auth
SECRET_KEY="replace_me_with_a_secure_random_string_for_production"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:8000/api/v1/auth/google/callback"
FRONTEND_URL="http://localhost:3000"

# AWS S3
AWS_ACCESS_KEY_ID="your_aws_access_key"
AWS_SECRET_ACCESS_KEY="your_aws_secret_key"
AWS_REGION="ap-south-1"
AWS_S3_BUCKET_NAME="your-bucket-name"
AWS_S3_PRESIGNED_EXPIRE_SECONDS=900

# AI Provider (nvidia, mock) — gemini is deprecated
AI_PROVIDER="nvidia"
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_BASE_URL="https://integrate.api.nvidia.com/v1"
NVIDIA_MODEL="meta/llama-3.2-11b-vision-instruct"

# Weather Provider (mock, openweather)
WEATHER_PROVIDER="openweather"
OPENWEATHER_API_KEY="your_openweather_api_key"
